        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "hebbs_active_subscriptions{job=\"hebbs\"}",
          "legendFormat": "active",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "gRPC Request Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
