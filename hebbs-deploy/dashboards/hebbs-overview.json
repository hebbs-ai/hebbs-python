      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(hebbs_grpc_requests_total{job=\"hebbs\"}[5m]))",
          "legendFormat": "gRPC req/s",
          "refId": "A",
