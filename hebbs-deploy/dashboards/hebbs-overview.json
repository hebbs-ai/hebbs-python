      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(hebbs_operation_duration_seconds_bucket{job=\"hebbs\", operation=\"prime\"}[5m])))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ]
