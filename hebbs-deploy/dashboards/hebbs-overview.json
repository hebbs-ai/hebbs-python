          "legendFormat": "similarity",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(hebbs_operation_duration_seconds_bucket{job=\"hebbs\", operation=\"recall\", strategy=\"temporal\"}[5m])))",
          "legendFormat": "temporal",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(hebbs_operation_duration_seconds_bucket{job=\"hebbs\", operation=\"recall\", strategy=\"causal\"}[5m])))",
          "legendFormat": "causal",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(hebbs_operation_duration_seconds_bucket{job=\"hebbs\", operation=\"recall\", strategy=\"analogical\"}[5m])))",
          "legendFormat": "analogical",
          "refId": "D"
        }
      ]
    },
    {
      "id": 7,
      "title": "Subscribe Push Latency (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
