    },
    {
      "id": 13,
      "title": "Reflect Runs Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "smooth",
            "fillOpacity": 60,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" },
            "axisPlacement": "auto",
            "lineWidth": 1,
            "barAlignment": 0
          },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
