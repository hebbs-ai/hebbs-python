  <script>
    // ── Fade-in on scroll ──
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.15 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    // ── Nav dots ──
    const stages = document.querySelectorAll('.stage');
    const dots = document.querySelectorAll('.nav-dot');
    const stageObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const idx = [...stages].indexOf(e.target);
          dots.forEach((d, i) => d.classList.toggle('active', i === idx));
        }
      });
    }, { threshold: 0.4 });
    stages.forEach(s => stageObs.observe(s));
    dots.forEach(d => d.addEventListener('click', () => {
      stages[parseInt(d.dataset.stage)].scrollIntoView({ behavior: 'smooth' });
    }));

    // ── Provider tabs ──
    document.querySelectorAll('.provider-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const p = tab.dataset.provider;
        document.querySelectorAll('.provider-tab').forEach(t => t.classList.toggle('active', t.dataset.provider === p));
        document.querySelectorAll('.provider-cmd').forEach(c => c.classList.toggle('active', c.dataset.provider === p));
      });
    });

    // ── Recall cards ──
    document.querySelectorAll('.recall-card').forEach(card => {
      card.addEventListener('click', () => {
        document.querySelectorAll('.recall-card').forEach(c => c.classList.remove('active'));
        card.classList.add('active');
      });
    });
  </script>
